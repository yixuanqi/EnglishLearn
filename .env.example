APP_NAME=English Trainer API
APP_VERSION=1.0.0
DEBUG=true

DATABASE_URL=sqlite+aiosqlite:///./english_trainer.db
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=dev_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

AI_PROVIDER=deepseek

AI_DEEPSEEK_API_KEY=your_deepseek_api_key_here
AI_DEEPSEEK_MODEL=deepseek-chat

AI_MINIMAX_API_KEY=your_minimax_api_key_here
AI_MINIMAX_MODEL=abab6.5s-chat

AI_DOUBAO_API_KEY=your_doubao_api_key_here
AI_DOUBAO_MODEL=doubao-pro

AI_AZURE_SPEECH_KEY=your_aliyun_access_key_here
AI_AZURE_SPEECH_REGION=cn-east-1

STRIPE_SECRET_KEY=your_stripe_secret_key_here

APPLE_SHARED_SECRET=your_apple_shared_secret_here
GOOGLE_PACKAGE_NAME=com.englishtrainer.app
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}

CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
