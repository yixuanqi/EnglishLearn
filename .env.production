APP_NAME=English Trainer API
APP_VERSION=1.0.0
DEBUG=false

POSTGRES_USER=english_trainer
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=english_trainer_prod

DATABASE_URL=postgresql+asyncpg://english_trainer:your_secure_postgres_password_here@postgres:5432/english_trainer_prod
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=your_very_secure_jwt_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

OPENAI_API_KEY=your_openai_api_key_here
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
STRIPE_SECRET_KEY=your_stripe_secret_key_here

APPLE_SHARED_SECRET=your_apple_shared_secret_here
GOOGLE_PACKAGE_NAME=com.englishtrainer.app
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}

CORS_ORIGINS=["https://englishspeakingtrainer.com"]

LOG_LEVEL=INFO
ENVIRONMENT=production
